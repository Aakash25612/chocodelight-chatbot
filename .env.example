# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-pro,gemini-pro-latest,gemini-2.5-flash

# Business Central (only needed on the sync machine)
# Company 1: Choco Delight (default company)
BC_BASE_URL=http://10.11.29.42:8848/ChocoDelight
BC_COMPANY_ID=058005c0-1940-ef11-aed1-2cea7fe9e541
BC_ODATA_COMPANY=Choco Delight Pvt. Ltd
BC_USERNAME=klnav\mobileapp
BC_PASSWORD=your_bc_password_here

# Company 2: Saurabh Food (same BC service account as Choco Delight)
BC_SAURABHFOOD_BASE_URL=http://10.11.29.42:8248/saurabhfood
BC_SAURABHFOOD_COMPANY_ID=5400b5d1-8b19-ef11-aed1-2cea7fe9e541
# Writes/posting: confirm the production OData codeunits before enabling writes.
BC_SAURABHFOOD_ODATA_COMPANY=SAURABH FOOD LIVE
BC_SAURABHFOOD_USERNAME=klnav\mobileapp
BC_SAURABHFOOD_PASSWORD=your_bc_password_here
# Set to true only after confirming the production OData company + codeunit for writes.
BC_SAURABHFOOD_WRITES_ENABLED=false

# supabase = cloud users read mirrored data from Supabase (recommended)
# direct = live BC calls from the app server (requires VPN on server)
BC_DATA_SOURCE=supabase
NEXT_PUBLIC_BC_DATA_SOURCE=supabase

# Secret for POST /api/sync (run from VPN machine on a schedule)
SYNC_SECRET=your_sync_secret_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
